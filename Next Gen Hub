<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Inter',sans-serif;
}

html{
scroll-behavior:smooth;
}

body{
background:#070B14;
color:white;
overflow-x:hidden;
}
.service-card:hover{
transform:translateY(-12px);
border-color:#8A88EB;
box-shadow:
0 20px 50px rgba(138,136,235,0.25),
0 0 30px rgba(138,136,235,0.15);
}

/* BACKGROUND GLOW */

.bg-blur1,
.bg-blur2{
position:absolute;
border-radius:50%;
filter:blur(120px);
z-index:-1;
}

.bg-blur1{
width:350px;
height:350px;
background:#8A88EB;
top:-120px;
left:-100px;
opacity:0.4;
}

.bg-blur2{
width:300px;
height:300px;
background:#5CE1E6;
right:-100px;
top:400px;
opacity:0.2;
}

/* NAVBAR */

.navbar{
position:fixed;
top:0;
width:100%;
padding:20px 8%;
display:flex;
justify-content:space-between;
align-items:center;
background:rgba(7,11,20,0.75);
backdrop-filter:blur(18px);
border-bottom:1px solid rgba(255,255,255,0.08);
z-index:1000;
}

.logo{
display:flex;
align-items:center;
gap:12px;
font-size:24px;
font-weight:700;
color:white;
}

.logo img{
width:52px;
height:52px;
border-radius:14px;
object-fit:cover;
}

.nav-links{
display:flex;
list-style:none;
gap:35px;
}

.nav-links a{
text-decoration:none;
color:#CBD5E1;
font-weight:500;
transition:0.3s;
}

.nav-links a:hover{
color:#8A88EB;
}

/* HERO */

.hero{
min-height:100vh;
display:flex;
align-items:center;
justify-content:space-between;
padding:130px 8%;
gap:60px;
position:relative;
}

.hero-text{
flex:1;
}

.hero-badge{
display:inline-block;
padding:10px 18px;
background:rgba(138,136,235,0.15);
border:1px solid rgba(138,136,235,0.25);
border-radius:50px;
color:#B9B8FF;
margin-bottom:25px;
font-size:14px;
}

.hero h1{
font-size:72px;
line-height:1.05;
font-weight:800;
margin-bottom:25px;
}

.hero h1 span{
background:linear-gradient(90deg,#8A88EB,#5CE1E6);
-webkit-background-clip:text;
-webkit-text-fill-color:transparent;
}

.hero p{
font-size:18px;
line-height:1.8;
color:#94A3B8;
max-width:620px;
margin-bottom:40px;
}

.hero-buttons{
display:flex;
gap:20px;
flex-wrap:wrap;
}

.btn{
padding:15px 32px;
border-radius:14px;
font-size:15px;
font-weight:600;
text-decoration:none;
transition:0.35s;
display:inline-block;
}

.primary-btn{
background:linear-gradient(135deg,#8A88EB,#5CE1E6);
color:white;
box-shadow:0 15px 35px rgba(138,136,235,0.35);
}

.primary-btn:hover{
transform:translateY(-5px);
}

.secondary-btn{
border:1px solid rgba(255,255,255,0.12);
background:rgba(255,255,255,0.03);
color:white;
}

.secondary-btn:hover{
background:rgba(255,255,255,0.08);
}

/* HERO CARD */

.hero-card{
flex:1;
max-width:480px;
background:rgba(255,255,255,0.05);
border:1px solid rgba(255,255,255,0.08);
border-radius:32px;
padding:40px;
backdrop-filter:blur(20px);
box-shadow:0 30px 60px rgba(0,0,0,0.45);
}

.hero-card h3{
font-size:30px;
margin-bottom:15px;
}

.hero-card p{
color:#CBD5E1;
line-height:1.7;
}

.stats{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:20px;
margin-top:35px;
}

.stat-box{
background:rgba(255,255,255,0.04);
padding:24px;
border-radius:22px;
text-align:center;
border:1px solid rgba(255,255,255,0.05);
}

.stat-box h2{
font-size:34px;
margin-bottom:8px;
color:#8A88EB;
}

.stat-box p{
font-size:14px;
color:#CBD5E1;
}

/* SECTION */

.section{
padding:110px 8%;
}

.section-title{
text-align:center;
margin-bottom:70px;
}

.section-title h2{
font-size:52px;
margin-bottom:15px;
}

.section-title p{
max-width:700px;
margin:auto;
line-height:1.8;
color:#94A3B8;
}

/* SERVICES */

.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:30px;
}

.service-card{
padding:40px;
border-radius:30px;
background:rgba(255,255,255,0.04);
border:1px solid rgba(255,255,255,0.08);
transition:0.4s;
position:relative;
overflow:hidden;
}

.service-card::before{
content:'';
position:absolute;
width:120px;
height:120px;
background:rgba(138,136,235,0.15);
border-radius:50%;
top:-40px;
right:-40px;
}

.service-card:hover{
transform:translateY(-10px);
border-color:#8A88EB;
box-shadow:0 20px 40px rgba(138,136,235,0.2);
}

.icon{
font-size:48px;
margin-bottom:20px;
}

.service-card h3{
font-size:26px;
margin-bottom:15px;
}

.service-card p{
line-height:1.8;
color:#CBD5E1;
}

/* ABOUT */

.about{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(320px,1fr));
gap:60px;
align-items:center;
}

.about-image{
height:420px;
border-radius:35px;
background:linear-gradient(135deg,#8A88EB,#4F46E5);
display:flex;
justify-content:center;
align-items:center;
font-size:52px;
font-weight:800;
text-align:center;
line-height:1.2;
box-shadow:0 30px 60px rgba(79,70,229,0.35);
}

.about-content h2{
font-size:52px;
margin-bottom:20px;
}

.about-content p{
line-height:1.9;
color:#CBD5E1;
margin-bottom:20px;
}

/* CONTACT */

.contact-box{
background:linear-gradient(135deg,
rgba(138,136,235,0.15),
rgba(92,225,230,0.08));
padding:70px;
border-radius:35px;
text-align:center;
border:1px solid rgba(255,255,255,0.08);
}

.contact-box h2{
font-size:48px;
margin-bottom:15px;
}

.contact-box p{
color:#CBD5E1;
line-height:1.8;
margin-bottom:30px;
}

.contact-info{
line-height:2.2;
font-size:18px;
margin-bottom:35px;
}

/* FOOTER */

footer{
padding:40px;
text-align:center;
color:#94A3B8;
border-top:1px solid rgba(255,255,255,0.08);
margin-top:70px;
}

/* MOBILE */

@media(max-width:950px){

.hero{
flex-direction:column;
text-align:center;
}

.hero h1{
font-size:52px;
}

.hero-buttons{
justify-content:center;
}

.nav-links{
display:none;
}

}

@media(max-width:600px){

.hero h1{
font-size:40px;
}

.section-title h2,
.about-content h2,
.contact-box h2{
font-size:34px;
}

.hero-card{
padding:28px;
}

.contact-box{
padding:45px 25px;
}

}

</style>
</head>

